@model IEnumerable<Expense_Manager.DataAccess.Entities.Income>

@{
    ViewData["Title"] = "My Income";
    decimal totalIncome = Model.Sum(i => i.Amount);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">💼 Income Tracker</h2>
            <p class="text-muted small">Manage and track your incoming revenues and deposits</p>
        </div>
        <a asp-action="Create" class="btn btn-success px-4 rounded-pill fw-bold">+ Add New Income</a>
    </div>

    <div class="card bg-success text-white border-0 shadow rounded-3 mb-4">
        <div class="card-body p-4">
            <h5 class="card-title text-uppercase opacity-75 small fw-bold">Total Earnings Logged</h5>
            <h1 class="display-5 fw-bold">Rs. @totalIncome.ToString("N2")</h1>
        </div>
    </div>

    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Date</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Amount</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <p class="mb-0">No incomes logged yet. Click "+ Add New Income" to start tracking!</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">@item.Date.ToString("MMM dd, yyyy")</td>
                                    <td><span class="badge bg-info text-dark px-2.5 py-1.5 rounded-pill">@item.Category?.Name</span></td>
                                    <td class="text-secondary">@item.Description</td>
                                    <td class="fw-bold text-success">Rs. @item.Amount.ToString("N2")</td>

                                    <td class="text-end pe-4">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="text-primary text-decoration-none fw-bold me-3 small">
                                            <i class="bi bi-pencil-square"></i> Edit
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this income entry?');" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-link text-danger p-0 border-0 text-decoration-none fw-bold small">
                                                <i class="bi bi-trash3-fill"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>