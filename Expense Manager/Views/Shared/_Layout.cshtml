@{
    // The Professional Method: Extract both Controller and Action to target exact locations
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExpenseManager</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Expense_Manager.styles.css" asp-append-version="true" />

    <style>
        /* Smooth underline indicator for the active route */
        .navbar-nav .nav-link {
            position: relative;
            padding-bottom: 6px;
            margin-right: 15px;
            font-weight: 500;
            color: #555 !important;
            transition: color 0.2s ease;
        }

            .navbar-nav .nav-link:hover {
                color: #198754 !important;
            }

            /* Active class accent marker line */
            .navbar-nav .nav-link.active {
                color: #198754 !important;
                font-weight: 700;
            }

                .navbar-nav .nav-link.active::after {
                    content: '';
                    position: absolute;
                    left: 0;
                    bottom: 0;
                    width: 100%;
                    height: 3px;
                    background-color: #198754;
                    border-radius: 2px;
                }

        .avatar-indicator {
            background-color: #e8f5e9;
            color: #198754;
            padding: 6px 14px;
            border-radius: 50px;
        }
    </style>
</head>
<body class="bg-light">
    <header class="sticky-top">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-success d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-wallet2 fs-4"></i> ExpenseManager
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-grid-1x2-fill me-1"></i> Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Income" ? "active" : "")" asp-controller="Income" asp-action="Index">
                                    <i class="bi bi-graph-up-arrow me-1"></i> My Income
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Expense" ? "active" : "")" asp-controller="Expense" asp-action="Index">
                                    <i class="bi bi-graph-down-arrow me-1"></i> My Expenses
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item me-3">
                                <span class="avatar-indicator small fw-bold d-flex align-items-center gap-1">
                                    <i class="bi bi-person-circle text-success"></i> Hello, @User.Identity.Name!
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-bold" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Account" && currentAction == "Login" ? "active" : "")" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Account" && currentAction == "Register" ? "active" : "")" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus me-1"></i> Register
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>